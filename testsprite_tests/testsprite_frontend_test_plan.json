[
  {
    "id": "TC001",
    "title": "Register a new user successfully and see email-confirmation messaging",
    "description": "Verifies a new user can submit the registration form and sees a visible confirmation/pending-verification state.",
    "category": "User Registration",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /register"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Create account\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Test User\" into the full name field"
      },
      {
        "type": "action",
        "description": "Type \"new.user.e2e+001@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"StrongPass!234\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Create account\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Check your email\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"verification\" is visible"
      }
    ]
  },
  {
