  {
    "id": "TC004",
    "title": "Request password reset email with a valid registered email",
    "description": "Verifies a user can submit the forgot-password form and see a success confirmation message.",
    "category": "Password Recovery",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"/forgot-password\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Forgot Password\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Click on \"Send reset link\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Password reset email sent\" is visible"
      }
    ]
  },
