      },
      {
        "type": "assertion",
        "description": "Verify text \"Weak\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"12345678\" into the password field"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Weak\" is visible"
      }
    ]
  },
